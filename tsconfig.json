{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2022"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true
  },
  "include": [],
  "files": [],
  "exclude": ["node_modules", "dist"],
  "references": [
    { "path": "packages/wallet-core" },
    { "path": "packages/agent-engine" },
    { "path": "packages/cli" },
    { "path": "demo" }
  ]
}
