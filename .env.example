# Please see .env.guide.md for detailed explanations of these variables

# NETWORK
SOLANA_RPC_URL=https://api.devnet.solana.com
SOLANA_CLUSTER=devnet

# SECURITY
WALLET_PASSPHRASE=change-me-to-a-strong-passphrase

# MASTER WALLET
# MASTER_WALLET_SECRET_KEY=your-base58-master-wallet-secret-key # for testing only, not recommended for production
MASTER_WALLET_KEY_LABEL=master-funder
AGENT_SEED_SOL=0.05
OWNER_ADDRESS=your-base58-owner-public-key
MERCHANT_RECEIVER_ADDRESS=your-base58-merchant-receiver-public-key # defaults to OWNER_ADDRESS if not set

# KORA GASLESS RELAY
KORA_RPC_URL=http://localhost:8080
# KORA_API_KEY=your-api-key-here
KORA_SIGNER_PRIVATE_KEY=kora/kora-signer.json
# KORA_SIGNER_PRIVATE_KEY=your-base58-kora-signer-private-key. Only use as an alternative to KORA_SIGNER_PRIVATE_KEY=kora/kora-signer.json if you cannot provide a file path.

# LOGGING
LOG_LEVEL=info

# ON-CHAIN REGISTRY & REPUTATION
# REGISTRY_WALLET_ADDRESS=DeKbktsRhJ4sWH344Fxzy52HoC4und9Vk4pcHUTvcWw5
# REPUTATION_PROGRAM_ID=A1N2w7TTbQXRcmV3xqq5dqsG6cja1mNmjkKKnKAXxDLz

# AGENT MANIFEST
AGENT_NAME=name-your-agent
AGENT_DESCRIPTION=describe-your-agent's-functionality-and-purpose

# PROTOCOL FEE (Revenue)
# PROTOCOL_FEE_ADDRESS=your-treasury-wallet-public-key
PROTOCOL_FEE_BPS=50  # 50 = 0.5% of every x402 payment
