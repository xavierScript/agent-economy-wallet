{
  "name": "agent-economy-wallet",
  "version": "1.0.0",
  "private": true,
  "description": "Programmatic Solana wallets — create, sign, hold tokens, and interact with on-chain programs",
  "type": "module",
  "scripts": {
    "build": "pnpm --filter @agent-economy-wallet/core build && pnpm --filter @agent-economy-wallet/cli build && pnpm --filter @agent-economy-wallet/mcp-server build && pnpm --filter agent-economy-wallet build",
    "dev": "pnpm -r --parallel dev",
    "start": "pnpm build && pnpm server",
    "server": "pnpm --filter @agent-economy-wallet/mcp-server build && node packages/mcp-server/dist/index.js",
    "cli": "pnpm --filter @agent-economy-wallet/cli build && node packages/cli/dist/index.js",
    "key:import": "pnpm --filter @agent-economy-wallet/core build && node packages/wallet-core/dist/scripts/import-system-keys.js",
    "test": "pnpm -r test",
    "lint": "pnpm -r lint",
    "clean": "pnpm -r clean",
    "register": "pnpm --filter @agent-economy-wallet/mcp-server build && node packages/mcp-server/dist/scripts/register.js"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "author": "xavierScript",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^20.19.33",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  }
}
