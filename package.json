{
  "name": "agentic-wallet",
  "version": "1.0.0",
  "description": "Programmatic Solana wallets — create, sign, hold tokens, and interact with on-chain programs",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "pnpm --filter @agentic-wallet/core build && pnpm --filter @agentic-wallet/cli build",
    "dev": "pnpm -r --parallel dev",
    "start": "pnpm build && pnpm --filter @agentic-wallet/examples start",
    "cli": "pnpm --filter @agentic-wallet/cli build && node packages/cli/dist/index.js",
    "dashboard:dev": "pnpm --filter @agentic-wallet/dashboard dev",
    "test": "pnpm -r test",
    "lint": "pnpm -r lint",
    "clean": "pnpm -r clean"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "author": "",
  "license": "MIT"
}
