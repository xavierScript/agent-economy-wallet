{
  "name": "@agent-economy-wallet/mcp-server",
  "version": "1.0.1",
  "description": "MCP server exposing Solana agent economy wallet tools for AI agents",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./api/server": {
      "import": "./dist/api/server.js",
      "types": "./dist/api/server.d.ts"
    }
  },
  "bin": {
    "agent-economy-wallet-mcp": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "clean": "rimraf dist"
  },
  "dependencies": {
    "@agent-economy-wallet/core": "workspace:*",
    "@modelcontextprotocol/sdk": "^1.12.1",
    "@solana/spl-token": "^0.4.14",
    "@solana/web3.js": "^1.95.0",
    "dotenv": "^16.4.5",
    "express": "^5.2.1",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^20.14.0",
    "rimraf": "^5.0.0",
    "typescript": "^5.4.0"
  }
}
